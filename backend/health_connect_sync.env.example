WI_GDRIVE_SERVICE_ACCOUNT_FILE=./service-account.json

# Use one of these:
# WI_GDRIVE_FILE_ID=your-google-drive-file-id
WI_GDRIVE_FOLDER_ID=your-google-drive-folder-id

# Optional: narrow folder search to files whose name contains this text.
WI_GDRIVE_NAME_CONTAINS=Health Connect

# Optional overrides.
WI_SYNC_COMMAND=go run ./cmd/health-connect-sync
WI_HEALTH_DB_FILENAME=health_connect_export.db
WI_HEALTH_DB_DEST=./health_connect_export.db
WI_EXPORTER_COMMAND=go run ./data_exporter.go
WI_FRONTEND_DATA_JSON=../frontend/data.json
WI_DIST_DATA_JSON=../frontend/dist/data.json
WI_SYNC_DOWNLOAD_DIR=./.sync-cache/download
WI_SYNC_EXTRACT_DIR=./.sync-cache/extracted
WI_SYNC_CLEANUP=true
